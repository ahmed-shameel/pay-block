# ─────────────────────────────────────────────────────────────
# PayBlock – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to source control.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payblock
DB_USER=payblock
DB_PASSWORD=changeme

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ── Blockchain (Ethereum / Polygon) ──────────────────────────
# RPC endpoint for the target network
BLOCKCHAIN_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY
# Private key of the deployer / hot wallet (never use a funded mainnet wallet here)
BLOCKCHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Deployed contract addresses (populated after `npm run deploy:contracts`)
PAYMENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_BLOCKCHAIN_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY
